// ============================================================
//  دندونة · مخطط قاعدة البيانات (Prisma)
//  منصة تقييم سلوكي متعلقة بالدوبامين — النسخة الأساسية
// ============================================================

generator client {
  provider = "prisma-client-js"
}

// ملاحظة (Prisma 7): رابط الاتصال يُضبط في prisma.config.ts عبر محوّل pg
datasource db {
  provider = "postgresql"
}

// ===================== التعدادات =====================
enum Role {
  USER          // فرد
  GUARDIAN        // ولي أمر
  SPECIALIST      // مختص
  INSTITUTION     // مؤسسة
  COMPANY         // شركة
  CONTENT_EDITOR  // مشرف محتوى (يدير المقاييس والتوصيات والمراجع)
  ADMIN           // مدير النظام
}

enum QuestionType {
  LIKERT
  SINGLE
  MULTI
  BOOLEAN
  NUMERIC
  TEXT
}

enum ScoringMethod {
  SUM
  AVERAGE
  WEIGHTED
  SUBSCALE
}

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum ConsentStatus {
  PENDING
  GRANTED
  REVOKED
  EXPIRED
}

enum RefSource {
  QURAN     // قرآن
  SUNNAH    // سنة
  SCHOLARLY // قول أهل العلم
  OTHER
}

// ===================== المستخدمون =====================
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime? // لمصادقة البريد (Auth.js)
  phone         String?   @unique
  passwordHash  String?
  fullName      String
  role          Role      @default(USER)
  isMinor       Boolean   @default(false)
  birthDate    DateTime?
  locale       String    @default("ar")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? // حذف منطقي لأغراض الاحتفاظ (PDPL)

  // علاقات
  accounts       Account[]
  sessions       Session[]
  guardianLinks  GuardianLink[] @relation("Guardian")
  wardLinks      GuardianLink[] @relation("Ward")
  children       Child[]        @relation("GuardianChildren")
  assessments    Assessment[]
  memberships    Membership[]
  consentsGranted Consent[]     @relation("ConsentGrantedBy")
  moods          MoodEntry[]
  auditLogs      AuditLog[]

  @@index([role])
  @@index([deletedAt])
}

// ===================== ملفات الأطفال =====================
// ولي الأمر (User) يملك ملفات أطفال متعددة. الطفل ليس حساب دخول مستقل.
model Child {
  id          String       @id @default(cuid())
  guardian    User         @relation("GuardianChildren", fields: [guardianId], references: [id], onDelete: Cascade)
  guardianId  String
  fullName    String
  birthDate   DateTime?
  gender      String?      // ذكر | أنثى | (اختياري)
  avatarColor String?      // لون رمزي للملف
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?    // حذف منطقي (PDPL)

  assessments Assessment[]
  consents    Consent[]
  plans       Plan[]
  specialistLinks SpecialistLink[]

  @@index([guardianId])
  @@index([deletedAt])
}

// ===================== الخطة والتحديات =====================
model Plan {
  id           String      @id @default(cuid())
  child        Child       @relation(fields: [childId], references: [id], onDelete: Cascade)
  childId      String
  assessmentId String?
  title        String
  createdAt    DateTime    @default(now())
  challenges   Challenge[]

  @@index([childId])
}

model Challenge {
  id          String   @id @default(cuid())
  plan        Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId      String
  title       String
  description String?
  order       Int      @default(0)
  done        Boolean  @default(false)

  @@index([planId])
}

// ===================== مشاركة المختص =====================
// ولي الأمر يشارك ملف طفل مع مختص (بالبريد). يظهر للمختص عند دخوله بنفس البريد.
model SpecialistLink {
  id              String   @id @default(cuid())
  child           Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  childId         String
  specialistEmail String
  grantedById     String   // ولي الأمر المشارِك
  createdAt       DateTime @default(now())

  @@unique([childId, specialistEmail])
  @@index([specialistEmail])
}

// ربط ولي الأمر بالقاصر
model GuardianLink {
  id         String   @id @default(cuid())
  guardian   User     @relation("Guardian", fields: [guardianId], references: [id], onDelete: Cascade)
  guardianId String
  ward       User     @relation("Ward", fields: [wardId], references: [id], onDelete: Cascade)
  wardId     String
  relation   String   // صلة القرابة
  createdAt  DateTime @default(now())

  @@unique([guardianId, wardId])
  @@index([wardId])
}

// ===================== مصادقة Auth.js =====================
model Account {
  id                String  @id @default(cuid())
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  expires      DateTime

  @@index([userId])
}

// رموز التحقق و OTP (بريد/جوال)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===================== المؤسسات =====================
model Organization {
  id          String       @id @default(cuid())
  name        String
  type        Role         // INSTITUTION | COMPANY
  seats       Int          @default(0)
  createdAt   DateTime     @default(now())

  memberships Membership[]
}

model Membership {
  id        String       @id @default(cuid())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  roleInOrg Role

  @@unique([userId, orgId])
  @@index([orgId])
}

// ===================== المقاييس =====================
model Scale {
  id          String         @id @default(cuid())
  code        String         @unique
  title       String
  description String?
  audience    Role           @default(USER)
  // بيانات وصفية: الفئة العمرية والتصنيف والمدة التقديرية
  category    String?        // مثل: التوازن الرقمي، التركيز، النوم، الانفعال
  minAge      Int?           // أصغر عمر مناسب (بالسنوات)
  maxAge      Int?           // أكبر عمر مناسب
  estMinutes  Int            @default(10)
  isActive    Boolean        @default(true)
  // اعتماد المحتوى: لا يظهر لمستخدم نهائي قبل اعتماد مختص/مدير
  approved    Boolean        @default(false)
  approvedAt  DateTime?
  createdAt   DateTime       @default(now())

  versions    ScaleVersion[]

  @@index([isActive])
  @@index([approved])
}

model ScaleVersion {
  id        String        @id @default(cuid())
  scale     Scale         @relation(fields: [scaleId], references: [id], onDelete: Cascade)
  scaleId   String
  version   Int
  scoring   ScoringMethod @default(SUM)
  isCurrent Boolean       @default(false)
  // مدى قيمة الخيار الواحد (للتطبيع إلى ٠–١٠٠): أدنى وأعلى قيمة ممكنة للخيار
  optionMin Float         @default(0)
  optionMax Float         @default(4)

  questions   Question[]
  bands       ScoreBand[]
  flags       ScaleFlag[]
  assessments Assessment[]

  @@unique([scaleId, version])
}

// عَلَم على مستوى المقياس: يتفعّل عند بلوغ درجة (الإجمالي أو محور) حدًّا معيّنًا
model ScaleFlag {
  id         String       @id @default(cuid())
  version    ScaleVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  versionId  String
  code       String       // GUARDIAN_REQUIRED | SPECIALIST_ADVISED | COUNSELOR_ADVISED ...
  label      String
  operator   String       @default("GTE") // GTE | LTE | GT | LT
  threshold  Float
  onSubscale String?      // null = الدرجة الإجمالية
  severity   String       @default("WARN") // WARN | CRITICAL

  @@index([versionId])
}

model Question {
  id        String       @id @default(cuid())
  version   ScaleVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  versionId String
  order     Int
  text      String
  type      QuestionType @default(LIKERT)
  weight    Float        @default(1)
  subscale  String?      // اسم المقياس الفرعي إن وجد
  isReverse Boolean      @default(false) // سؤال عكسي (تُقلب قيمته عند الاحتساب)
  // عَلَم تنبيهي: إذا بلغت قيمة الإجابة هذا الحد أو تجاوزته يُرفع تنبيه
  flagThreshold Float?
  flagLabel     String?  // نص التنبيه المعروض للمختص/ولي الأمر

  options   QuestionOption[]
  responses Response[]

  @@index([versionId])
}

model QuestionOption {
  id         String   @id @default(cuid())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String
  label      String
  value      Float    // القيمة الرقمية للاحتساب
  order      Int

  @@index([questionId])
}

// نطاقات التفسير: خام ← نطاق ← تفسير + توصية
model ScoreBand {
  id             String        @id @default(cuid())
  version        ScaleVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  versionId      String
  subscale       String?
  minScore       Float
  maxScore       Float
  label          String        // منخفض | متوسط | مرتفع
  interpretation String

  recommendations Recommendation[]

  @@index([versionId])
}

// ===================== التوصيات والمراجع الشرعية =====================
model Recommendation {
  id        String    @id @default(cuid())
  band      ScoreBand @relation(fields: [bandId], references: [id], onDelete: Cascade)
  bandId    String
  title     String
  body      String
  order     Int       @default(0)

  references RecommendationReference[]

  @@index([bandId])
}

// مرجع شرعي (قرآن/سنة/قول أهل العلم)
model IslamicReference {
  id        String    @id @default(cuid())
  source    RefSource @default(SCHOLARLY)
  title     String
  textAr    String            // نص المرجع
  citation  String?           // الإحالة (سورة/آية، أو تخريج الحديث)
  category  String?
  createdAt DateTime  @default(now())

  usedIn    RecommendationReference[]
}

// ربط التوصية بمرجع شرعي (متعدد لمتعدد)
model RecommendationReference {
  id               String           @id @default(cuid())
  recommendation   Recommendation   @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  recommendationId String
  reference        IslamicReference @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  referenceId      String

  @@unique([recommendationId, referenceId])
}

// ===================== الجلسات والنتائج =====================
model Assessment {
  id          String           @id @default(cuid())
  // ولي الأمر المنفّذ للجلسة
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  // الطفل موضوع التقييم (اختياري: قد يقيّم بالغٌ نفسه)
  child       Child?           @relation(fields: [childId], references: [id], onDelete: Cascade)
  childId     String?
  version     ScaleVersion     @relation(fields: [versionId], references: [id])
  versionId   String
  status      AssessmentStatus @default(IN_PROGRESS)
  startedAt   DateTime         @default(now())
  completedAt DateTime?

  responses Response[]
  results   ScaleResult[]

  @@index([userId])
  @@index([childId])
  @@index([status])
}

model Response {
  id           String     @id @default(cuid())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId String
  question     Question   @relation(fields: [questionId], references: [id])
  questionId   String
  value        Float?     // للأنواع الرقمية/الخيارات
  textValue    String?    // للنوع النصي
  createdAt    DateTime   @default(now())

  @@unique([assessmentId, questionId])
}

model ScaleResult {
  id              String     @id @default(cuid())
  assessment      Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId    String
  subscale        String?
  rawScore        Float
  normalizedScore Float      @default(0) // الدرجة المطبّعة ٠–١٠٠
  band            String
  interpretation  String
  flags           Json?      // الأعلام التنبيهية المرفوعة (مصفوفة نصوص)
  createdAt       DateTime   @default(now())

  @@index([assessmentId])
}

// ===================== ركن الطمأنينة (المزاج) =====================
model MoodEntry {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  mood      Int      // 1..5 (منتقي المزاج)
  note      String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ===================== الموافقة (PDPL) =====================
model Consent {
  id            String        @id @default(cuid())
  // صاحب البيانات: ملف الطفل
  child         Child         @relation(fields: [childId], references: [id], onDelete: Cascade)
  childId       String
  // مانح الموافقة (ولي الأمر)
  grantedByUser User          @relation("ConsentGrantedBy", fields: [grantedById], references: [id], onDelete: Cascade)
  grantedById   String
  purpose       String        // الغرض من المعالجة
  status        ConsentStatus @default(PENDING)
  grantedAt     DateTime?
  revokedAt     DateTime?
  expiresAt     DateTime?
  createdAt     DateTime      @default(now())

  @@index([childId, status])
}

// ===================== التدقيق =====================
model AuditLog {
  id        String   @id @default(cuid())
  actor     User?    @relation(fields: [actorId], references: [id])
  actorId   String?
  action    String   // نوع الحدث
  entity    String   // الكيان المتأثر
  entityId  String?
  ipAddress String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, createdAt])
}
