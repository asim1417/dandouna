# ===== قاعدة البيانات (Postgres) =====
# على Vercel استخدم Vercel Postgres أو Neon. مثال:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dandouna?sslmode=require"

# ===== Auth.js =====
# ولّد المفتاح بأمر: openssl rand -base64 32
AUTH_SECRET="ضع-مفتاحًا-عشوائيًا-هنا"
# عنوان الموقع (على Vercel يُضبط تلقائيًا)
NEXTAUTH_URL="http://localhost:3000"

# ===== تسجيل الدخول عبر Google (اختياري) =====
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ===== البريد (OTP) — اختياري =====
# لإرسال رموز الدخول فعليًا في الإنتاج. بدونها تُطبع الرموز في السجل (تطوير فقط).
RESEND_API_KEY=""
EMAIL_FROM="دندونة <no-reply@dandouna.sa>"

# ===== جولة تجريبية (اختياري) =====
# فعّلها لإظهار زر "دخول كضيف" الذي يدخل بحساب تجريبي بلا تسجيل
DEMO_MODE="false"
NEXT_PUBLIC_DEMO_MODE="false"
